generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique   // 👈 ВАЖНО
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  phone        String
  status       String   @default("NEW") // "NEW", "IN_PROGRESS", "READY"
  productId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
}