generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  phone        String
  status       String   @default("NEW") // "NEW", "IN_PROGRESS", "READY"
  productId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
